# ── 选择 LLM 提供商 ────────────────────────────────────────────────────────────
# LLM_PROVIDER 可选值：anthropic | openai | deepseek | qwen
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat       # deepseek-chat=V3  deepseek-reasoner=R1

# ── API Keys（只需填写你使用的那个）────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...       # platform.deepseek.com → API Keys
QWEN_API_KEY=sk-...           # dashscope.aliyuncs.com → API Key管理

# ── 向量嵌入（知识库检索用）────────────────────────────────────────────────────
# EMBEDDING_PROVIDER 可选值：qwen | openai | local
# 不填则自动选择：有 QWEN_API_KEY → qwen，有 OPENAI_API_KEY → openai，否则 local
# EMBEDDING_PROVIDER=qwen
# EMBEDDING_MODEL=text-embedding-v3   # qwen 默认；openai 默认 text-embedding-3-small
